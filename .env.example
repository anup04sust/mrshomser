# Ollama Configuration
# URL to Ollama service (internal Docker network)
OLLAMA_API_URL=http://ollama:11434

# AI model to use
# Recommended: phi3:mini (2.3GB, fast on CPU, good quality)
# Alternatives: tinyllama:1.1b (fastest), llama2 (best quality, needs GPU)
OLLAMA_MODEL=phi3:mini

# MongoDB Configuration
# Connection string for MongoDB (internal Docker network)
MONGODB_URI=mongodb://db:db@mongo:27017/mrshomser?authSource=admin
# Database name
MONGODB_DB=mrshomser

# App Configuration
# Application name displayed in UI
NEXT_PUBLIC_APP_NAME=Mr Shomser

# JWT Secret for Authentication
# ⚠️ CRITICAL: Generate a secure random secret for production!
# Use: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters required
JWT_SECRET=GENERATE_A_SECURE_SECRET_MINIMUM_32_CHARS
